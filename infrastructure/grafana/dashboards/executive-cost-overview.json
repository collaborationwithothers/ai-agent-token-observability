      "id": 5,
      "targets": [
        {
          "expr": "sum by (harness) (increase(tokenobs_tokens_total{environment=~\"$environment\",region=~\"$region\",token_type=~\"input|output|cached_input|reasoning_output|total\"}[$__range]))",
