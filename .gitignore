# Local .terraform directories
.terraform/

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and other secrets. These should not be part of version
# control as they are data points which are potentially sensitive and subject
# to change depending on the environment.
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally and so
# are not checked in
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore transient lock info files created by terraform apply
.terraform.tfstate.lock.info

# Include override files you do wish to add to version control using negated pattern
# !example_override.tf

# Include tfplan files to ignore the plan output of command: terraform plan -out=tfplan
# example: *tfplan*
tfplan
tfplan.*
*.tfplan
*.tfplan.*
planout
*.planout

# Terraform graph and diagnostics artifacts
*.dot
*.tfplan.json
terraform-plan.json
terraform-plan.txt

# Ignore CLI configuration files
.terraformrc
terraform.rc

# .NET build outputs
bin/
obj/
TestResults/
coverage/

# Frontend dependencies and build outputs
node_modules/
web/token-observability-dashboard/dist/
web/token-observability-dashboard/tsconfig.tsbuildinfo
web/token-observability-dashboard/coverage/
web/token-observability-dashboard/.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local telemetry captures and scratch data
.local/

# Transient Code Reviewer output
Comments.md

# Codex and validation scratch output
codex-output.md
validation-output.md
validation-output.txt
*.validation.log
