@page "/"
@using AiAgentTokenObservability.Contracts.Sessions
@inject DashboardInsightsClient InsightsClient
@inject DashboardSessionsClient SessionsClient
@inject DashboardStatusClient StatusClient

<PageTitle>Local Dashboard</PageTitle>

<h1>Local Dashboard</h1>

@if (_status is null && _error is null)
{
    <p>Loading local platform status...</p>
}
else if (_error is not null)
{
    <div class="alert alert-warning" role="alert">
        Dashboard API status is unavailable: @_error
    </div>
}
else if (_status is not null)
{
    <section class="status-panel" aria-label="Local platform status">
        <div>
            <span class="status-label">Platform</span>
            <strong>@_status.PlatformName</strong>
        </div>
        <div>
            <span class="status-label">Environment</span>
            <strong>@_status.EnvironmentName</strong>
        </div>
        <div>
            <span class="status-label">Local Store</span>
            <strong>@_status.StoreName</strong>
        </div>
        <div>
            <span class="status-label">Last Updated</span>
            <strong>@_status.GeneratedAtUtc.ToLocalTime().ToString("u")</strong>
        </div>
    </section>

    <h2>Local Pipeline Projects</h2>
    <ul class="pipeline-list">
        @foreach (var project in _status.PipelineProjects)
        {
            <li>@project</li>
        }
    </ul>
}

<h2>Imported Sessions</h2>

@if (_sessions is null && _sessionsError is null)
{
    <p>Loading imported sessions...</p>
}
else if (_sessionsError is not null)
{
    <div class="alert alert-warning" role="alert">
        Imported sessions are unavailable: @_sessionsError
    </div>
}
else if (_sessions is { Sessions.Count: 0 })
{
    <p>No imported sessions found.</p>
}
else if (_sessions is not null)
{
    <div class="session-table-wrap">
        <table class="session-table">
            <thead>
                <tr>
                    <th scope="col">Harness</th>
                    <th scope="col">Agent</th>
                    <th scope="col">Started</th>
                    <th scope="col">Token Split</th>
                    <th scope="col">Turns</th>
                    <th scope="col">Tools</th>
                    <th scope="col">Models</th>
                    <th scope="col">Repos</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var session in _sessions.Sessions)
                {
                    <tr>
                        <td>
                            <strong>@session.Harness</strong>
                            @if (!string.IsNullOrWhiteSpace(session.HarnessVersion))
                            {
                                <span>@session.HarnessVersion</span>
                            }
                        </td>
                        <td>@(session.AgentName ?? session.HarnessSource ?? "Unknown")</td>
                        <td>@FormatDate(session.StartedAtUtc)</td>
                        <td>
                            <span class="token-status">@session.TokenSplit.TokenTotalType</span>
                            <span>@DashboardTokenFormatter.FormatTokens(session.TokenSplit.InputTokens) input</span>
                            <span>@DashboardTokenFormatter.FormatTokens(session.TokenSplit.OutputTokens) output</span>
                            @foreach (var metric in session.TokenSplit.Metrics)
                            {
                                <span class="token-metric">
                                    @FormatMetricName(metric.MetricName):
                                    @DashboardTokenFormatter.FormatTokens(metric.Value)
                                    (@metric.MetricStatus, @metric.MetricConfidence)
                                </span>
                            }
                        </td>
                        <td>@session.TurnCount</td>
                        <td>@session.ToolCallCount</td>
                        <td>@session.ModelInvocationCount</td>
                        <td>@session.WorkspaceRepoCount</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<h2>Token Hotspots</h2>

@if (_insights is null && _insightsError is null)
{
    <p>Loading token hotspots...</p>
}
else if (_insightsError is not null)
{
    <div class="alert alert-warning" role="alert">
        Token hotspots are unavailable: @_insightsError
    </div>
}
else if (_insights is { Hotspots.Count: 0 })
{
    <p>No token hotspots found.</p>
}
else if (_insights is not null)
{
    <div class="session-table-wrap">
        <table class="session-table">
            <thead>
                <tr>
                    <th scope="col">Source</th>
                    <th scope="col">Attribution</th>
                    <th scope="col">Confidence</th>
                    <th scope="col">Cause</th>
                    <th scope="col">Recommendation</th>
                    <th scope="col">Expected Benefit</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var hotspot in _insights.Hotspots)
                {
                    var recommendation = hotspot.Recommendations.FirstOrDefault();
                    <tr>
                        <td>
                            <strong>@hotspot.SourceType</strong>
                            <span>@(hotspot.SourceRef ?? "Unknown")</span>
                        </td>
                        <td>@hotspot.AttributionType</td>
                        <td>@hotspot.Confidence</td>
                        <td>@hotspot.SuspectedCause</td>
                        <td>
                            @if (recommendation is null)
                            {
                                <span>No recommendation</span>
                            }
                            else
                            {
                                <strong>@recommendation.RuleId</strong>
                                <span>@recommendation.RecommendedAction</span>
                            }
                        </td>
                        <td>@(recommendation?.ExpectedBenefit ?? "Unknown")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<h2>Repo Context Sources</h2>

@if (_insights is null && _insightsError is null)
{
    <p>Loading repo context sources...</p>
}
else if (_insightsError is not null)
{
    <div class="alert alert-warning" role="alert">
        Repo context sources are unavailable: @_insightsError
    </div>
}
else if (_insights is { ContextSources.Count: 0 })
{
    <p>No repo context sources found.</p>
}
else if (_insights is not null)
{
    <div class="session-table-wrap">
        <table class="session-table">
            <thead>
                <tr>
                    <th scope="col">Source Type</th>
                    <th scope="col">File Category</th>
                    <th scope="col">Spec Status</th>
                    <th scope="col">Eligible</th>
                    <th scope="col">Size</th>
                    <th scope="col">Lines</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var source in _insights.ContextSources)
                {
                    <tr>
                        <td>@source.SourceType</td>
                        <td>@source.FileCategory</td>
                        <td>@(source.SpecArtifactStatus ?? "Not applicable")</td>
                        <td>@(source.EligibleForInferredHotspot ? "Yes" : "No")</td>
                        <td>@(source.SizeBytes?.ToString() ?? "Unknown")</td>
                        <td>@(source.LineCount?.ToString() ?? "Unknown")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private DashboardStatusResponse? _status;
    private DashboardSessionsResponse? _sessions;
    private DashboardInsightsResponse? _insights;
    private string? _error;
    private string? _sessionsError;
    private string? _insightsError;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _status = await StatusClient.GetStatusAsync(CancellationToken.None);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }

        try
        {
            _sessions = await SessionsClient.GetSessionsAsync(CancellationToken.None);
        }
        catch (Exception ex)
        {
            _sessionsError = ex.Message;
        }

        try
        {
            _insights = await InsightsClient.GetInsightsAsync(CancellationToken.None);
        }
        catch (Exception ex)
        {
            _insightsError = ex.Message;
        }
    }

    private static string FormatDate(DateTimeOffset? value)
    {
        return value is null ? "Unknown" : value.Value.ToLocalTime().ToString("u");
    }

    private static string FormatMetricName(string metricName)
    {
        return metricName.Replace('_', ' ');
    }
}
